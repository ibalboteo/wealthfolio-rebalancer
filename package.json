{
  "name": "wealthfolio-rebalancer-addon",
  "version": "3.1.0",
  "description": "Rebalancer calculates the exact trades you need to keep your portfolio on target, on demand.",
  "type": "module",
  "main": "dist/addon.js",
  "packageManager": "pnpm@10.34.5",
  "keywords": [
    "wealthfolio",
    "addon"
  ],
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "dev:server": "wealthfolio dev",
    "clean": "rm -rf dist",
    "package": "mkdir -p dist && zip -r dist/$npm_package_name-$npm_package_version.zip manifest.json dist/ assets/ README.md",
    "bundle": "pnpm clean && pnpm build && pnpm package",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "type-check": "tsc --noEmit",
    "i18n:extract": "i18next-cli extract --sync-primary",
    "i18n:types": "i18next-cli types",
    "i18n": "i18next-cli extract --sync-primary --with-types",
    "test": "vitest run",
    "prepare": "lefthook install",
    "version": "node -e \"const fs=require('fs'); const pkg=require('./package.json'); const manifest=require('./manifest.json'); manifest.version=pkg.version; fs.writeFileSync('manifest.json',JSON.stringify(manifest,null,2)+'\\n');\" && git add manifest.json",
    "release": "pnpm version",
    "release:patch": "pnpm version patch && git push --follow-tags",
    "release:minor": "pnpm version minor && git push --follow-tags",
    "release:major": "pnpm version major && git push --follow-tags"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@wealthfolio/addon-sdk": "^3.6.2",
    "@wealthfolio/ui": "^3.6.2",
    "i18next": "^25.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.10",
    "@wealthfolio/addon-dev-tools": "^3.6.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "i18next-cli": "^1.66.2",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
