{
  "id": "rebalancer",
  "name": "rebalancer",
  "version": "3.0.0",
  "description": "Rebalancer calculates the exact trades you need to keep your portfolio on target, on demand.",
  "author": "Ivan Balboteo",
  "main": "dist/addon.js",
  "sdkVersion": "3.6.0",
  "minWealthfolioVersion": "3.6.0",
  "contributes": {
    "routes": [
      {
        "id": "main"
      }
    ],
    "links": {
      "sidebar": [
        {
          "id": "main-nav",
          "route": "main",
          "label": "Rebalancer",
          "icon": "scales",
          "order": 100
        }
      ]
    }
  },
  "enabled": true,
  "permissions": [
    {
      "category": "ui",
      "functions": [
        "router.add"
      ],
      "purpose": "Register addon routes in the UI"
    },
    {
      "category": "accounts",
      "functions": [
        "getAll"
      ],
      "purpose": "Access account information for portfolio rebalancing"
    },
    {
      "category": "portfolio",
      "functions": [
        "getHoldings"
      ],
      "purpose": "Read portfolio holdings to calculate rebalancing recommendations"
    },
    {
      "category": "navigation",
      "functions": [
        "navigate"
      ],
      "purpose": "Navigate to activities page for transaction management"
    }
  ],
  "keywords": [
    "wealthfolio",
    "addon"
  ],
  "license": "MIT"
}
